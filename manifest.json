{
  "manifest_version": 3,
  "name": "Close Similar Tabs",
  "description": "Closes tabs with the same domain.",
  "author": "Salamandar",
  "developer": {
    "name": "Salamandar",
    "url": "https://github.com/Salamandar"
  },
  "homepage_url": "https://github.com/Salamandar/firefox-webext-close-similar-tabs.git",
  "version": "1.0",

  "icons": {
    "48": "icons/close-tabs.svg"
  },

  "permissions": [
    "tabs",
    "theme"
  ],

  "action": {
    "default_icon": {
      "48": "icons/close-tabs.svg"
    },
    "default_title": "Close Tabs",
    "default_popup": "src/close-tabs.html"
  },

  "browser_specific_settings": {
    "gecko": {
      "id": "close-similar-tabs@salamandar.fr",
      "strict_min_version": "142.0",
      "data_collection_permissions": {
        "required": ["none"]
      }
    },

    "gecko_android": {
      "strict_min_version": "142.0"
    }
  }
}
